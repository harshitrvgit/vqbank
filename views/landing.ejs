<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="<%= description || 'Search, browse, and download VIT Vellore previous year question papers on vqBank.' %>">
    <meta name="robots" content="index,follow">
    <link rel="canonical" href="<%= canonicalUrl || 'https://vqbank.harshitrv.in/landing' %>">
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="vqBank">
    <meta property="og:title" content="<%= title || 'vqBank - VIT Vellore Previous Year Question Papers' %>">
    <meta property="og:description" content="<%= description || 'Search, browse, and download VIT Vellore previous year question papers on vqBank.' %>">
    <meta property="og:url" content="<%= canonicalUrl || 'https://vqbank.harshitrv.in/landing' %>">
    <meta property="og:image" content="<%= siteUrl || 'https://vqbank.harshitrv.in' %>/assets/favicons/android-chrome-512x512.png">
    <meta name="twitter:card" content="summary">
    <meta name="twitter:title" content="<%= title || 'vqBank - VIT Vellore Previous Year Question Papers' %>">
    <meta name="twitter:description" content="<%= description || 'Search, browse, and download VIT Vellore previous year question papers on vqBank.' %>">
    <meta name="twitter:image" content="<%= siteUrl || 'https://vqbank.harshitrv.in' %>/assets/favicons/android-chrome-512x512.png">
    <link rel="shortcut icon" href="/assets/favicons/android-chrome-512x512.png" type="image/x-icon">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-rbsA2VBKQhggwzxH7pPCaAqO46MgnOM80zW1RWuH61DGLwZJEdK2Kadq2F9CUG65" crossorigin="anonymous">
    <link rel="stylesheet" href="/css/landing.css">
    <title id="title"><%= title || 'vqBank - VIT Vellore Previous Year Question Papers' %></title>
    <% if (structuredData) { %>
        <script type="application/ld+json"><%- JSON.stringify(structuredData) %></script>
    <% } %>
</head>

<body class="container bg-dark text-center">
    <div class="center-item">
        <h1 class="text-light">Welcome to vQbank</h1>
        <p class="text-light">
            Search VIT Vellore previous year question papers by course, programme, semester, and assessment type.
        </p>
        <a href="/papers" class="btn btn-primary btn-lg">Browse Papers</a>
        <p class="text-light mt-3 mb-1">No account needed to view or download papers.</p>
        <a href="/api/v1/login" class="btn btn-outline-light btn-sm">Login</a>
        <a href="/api/v1/register" class="btn btn-outline-success btn-sm">Sign Up</a>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-kenU1KFdBIe4zVF0s0G1M5b4hcpxyD9F7jL+jjXkk+Q2h455rYXK/7HAuoJl+0I4"
        crossorigin="anonymous"></script>
</body>

</html>
